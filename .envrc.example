# Copy this file to .envrc and install direnv (https://direnv.net)
# to auto-activate the virtualenv when you enter the project directory.
#   cp .envrc.example .envrc
#   direnv allow
if has uv; then
  watch_file pyproject.toml
  watch_file uv.lock
  uv sync --quiet --native-tls --frozen
  . .venv/bin/activate
fi
